"""Kitty Framework Environment Configuration.

Copy this file to .env and fill in your values.
   cp .env.example .env

Required variables are marked with (required).
Optional variables show their default value.
"""

# ============================================================
# LLM Provider API Keys
# ============================================================

# OpenAI API key (required for OpenAI provider integration)
OPENAI_API_KEY="sk-..."

# Anthropic API key (required for Anthropic provider integration)
ANTHROPIC_API_KEY="sk-ant-..."

# Custom API Base URLs - override the default endpoint for each provider.
# Useful for proxies, self-hosted gateways, or provider-compatible APIs.
OPENAI_BASE_URL="https://api.openai.com/v1"
ANTHROPIC_BASE_URL="https://api.anthropic.com"
AZURE_OPENAI_ENDPOINT=""
OLLAMA_BASE_URL="http://localhost:11434"

# Google Gemini (optional)
GEMINI_API_KEY=""

# ============================================================
# Database Configuration
# ============================================================

# SQLite (default for local development):
#   sqlite+aiosqlite:////data/kitty.db
# MySQL (production):
#   mysql+aiomysql://kitty:password@mysql:3306/kitty
# PostgreSQL (production):
#   postgresql+asyncpg://kitty:password@postgres:5432/kitty
KITTY_DATABASE_URL="sqlite+aiosqlite:///kitty.db"

# ============================================================
# Redis Configuration
# ============================================================

# Redis connection string (required for caching and task queues)
# Format: redis://[[username]:[password]]@host:port/db
KITTY_REDIS_URL="redis://localhost:6379/0"

# ============================================================
# Application Secrets
# ============================================================

# Secret key for signing JWT tokens and encrypting sensitive data
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
KITTY_SECRET="change-me-to-a-random-secret"

# ============================================================
# Logging
# ============================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL="INFO"

# Log format: json, text
KITTY_LOG_FORMAT="text"

# ============================================================
# Cache Configuration
# ============================================================

# Path for local disk cache (used when Redis is unavailable)
KITTY_CACHE_PATH="/tmp/kitty-cache"

# Cache TTL in seconds (default: 3600 = 1 hour)
KITTY_CACHE_TTL="3600"

# ============================================================
# Rate Limiting
# ============================================================

# Maximum API requests per second per provider
KITTY_RATE_LIMIT_RPS="10"

# Maximum concurrent API calls
KITTY_MAX_CONCURRENCY="5"

# ============================================================
# Server Configuration
# ============================================================

# API server host and port
KITTY_HOST="0.0.0.0"
KITTY_PORT="15500"

# CORS allowed origins (comma-separated)
KITTY_CORS_ORIGINS="http://localhost:3000,http://localhost:15500"

# ============================================================
# Worker Configuration
# ============================================================

# Number of worker processes
KITTY_WORKER_CONCURRENCY="4"

# ============================================================
# Proxy Configuration
# ============================================================

# HTTP/HTTPS proxy for all outbound LLM API requests
HTTP_PROXY=""
HTTPS_PROXY=""

# ============================================================
# Telemetry & Observability
# ============================================================

# OpenTelemetry endpoint (e.g., http://otel-collector:4318/v1/traces)
OTEL_EXPORTER_OTLP_ENDPOINT=""

# OpenTelemetry service name
OTEL_SERVICE_NAME="kitty"

# Sentry DSN for error tracking (optional)
SENTRY_DSN=""

# ============================================================
# Docker Compose (override for production deployment)
# ============================================================

# MySQL password (used by docker-compose.yml when KITTY_DATABASE_URL uses mysql)
MYSQL_PASSWORD=""

# Docker image tag
KITTY_IMAGE_TAG="latest"
